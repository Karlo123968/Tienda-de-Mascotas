@page
@model ServiciosModel
@{
    ViewData["Title"] = "Servicios";
}

<h1 class="text-center mb-4">🩺 Servicios</h1>

<div class="row">

    <div class="col-md-3">
        <div class="card shadow text-center p-3">
            <h4>🛁 Baño</h4>
            <p>Servicio de limpieza y estética para mascotas.</p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow text-center p-3">
            <h4>🩺 Veterinaria</h4>
            <p>Consultas médicas para tus mascotas.</p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow text-center p-3">
            <h4>💉 Vacunación</h4>
            <p>Aplicación de vacunas necesarias.</p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow text-center p-3">
            <h4>🏠 Adopción</h4>
            <p>Encuentra una mascota para tu hogar.</p>
        </div>
    </div>

</div>