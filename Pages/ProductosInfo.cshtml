@page
@model ProductosInfoModel
@{
    ViewData["Title"] = "Productos";
}

<h1 class="text-center mb-4">🛒 Productos</h1>

<div class="row">

    <div class="col-md-3">
        <div class="card shadow text-center p-3">
            <h4>🍖 Alimento</h4>
            <p>Alimentos balanceados para todo tipo de mascotas.</p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow text-center p-3">
            <h4>🧸 Juguetes</h4>
            <p>Juguetes para entretenimiento y ejercicio.</p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow text-center p-3">
            <h4>🎀 Accesorios</h4>
            <p>Collares, correas y ropa para mascotas.</p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow text-center p-3">
            <h4>💊 Medicamentos</h4>
            <p>Productos para el cuidado y salud.</p>
        </div>
    </div>

</div>