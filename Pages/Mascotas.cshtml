@page
@model MascotasModel
@{
    ViewData["Title"] = "Mascotas";
}

<h1 class="text-center mb-4">🐾 Nuestras Mascotas</h1>

<div class="row">

    <div class="col-md-3">
        <div class="card shadow text-center p-3">
            <h4>🐶 Perros</h4>
            <p>Diferentes razas y tamaños ideales para compañía.</p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow text-center p-3">
            <h4>🐱 Gatos</h4>
            <p>Domésticos y de raza, perfectos para el hogar.</p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow text-center p-3">
            <h4>🐦 Aves</h4>
            <p>Canarios, pericos y aves exóticas.</p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow text-center p-3">
            <h4>🐠 Peces</h4>
            <p>Variedad de peces de agua dulce y salada.</p>
        </div>
    </div>

</div>